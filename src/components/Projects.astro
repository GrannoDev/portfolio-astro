---
import ProjectCard from './ProjectCard.astro';
import climbalongImg from '../assets/climbalong.png';
import silverballImg from '../assets/silverball.png';
import sveltetodoImg from '../assets/sveltetodo.jpg';
import knapoghugImg from '../assets/knapoghug.jpg';

const projects = [
  {
    title: 'ClimbAlong',
    description: 'Digital climbing platform where I helped build performant user experiences and scalable application features.',
    tech: ['Angular', 'TypeScript', 'Java / Spring Boot', 'Tailwind CSS', 'PostgreSQL'],
    image: climbalongImg,
    url: 'https://climbalong.com/',
    github: '',
    urlLabel: 'Visit site',
  },
  {
    title: 'Silverball',
    description: 'Danish gaming pub website centered on pinball culture, built for discoverability and a clear content experience.',
    tech: ['Svelte / SvelteKit', 'TypeScript', 'Tailwind CSS', 'Firebase'],
    image: silverballImg,
    url: 'https://silverball.dk/',
    github: '',
    urlLabel: 'Check the site',
  },
  {
    title: 'Knap & Hug',
    description: 'Web app for managing my fishing club with friends — organizing trips, tracking catches, and staying connected.',
    tech: ['SvelteKit', 'TypeScript', 'Tailwind CSS', 'Convex', 'Better Auth'],
    image: knapoghugImg,
    url: 'https://knapoghug.com/',
    github: '',
    urlLabel: 'Take a look',
  },
  {
    title: 'Todo List',
    description: 'A simple yet effective todo list application built with modern web technologies and tested with Vitest.',
    tech: ['Svelte / SvelteKit', 'Tailwind CSS', 'DexieJS', 'Vitest'],
    image: sveltetodoImg,
    url: 'https://svelte-todos-simple.netlify.app/',
    github: 'https://github.com/GrannoDev/svelte-todo',
    urlLabel: 'Try it out',
  },
  {
    title: 'Pirate Whist',
    description: 'Browser-based trick-taking card game with IndexedDB-powered persistence for a smooth in-browser experience.',
    tech: ['Svelte / SvelteKit', 'Tailwind CSS / DaisyUI', 'DexieJS'],
    image: null,
    url: 'https://piratewhist.netlify.app/',
    github: 'https://github.com/GrannoDev/pirate-whist',
    urlLabel: 'Play now',
  },
];
---

<section id="projects" class="container mx-auto w-full max-w-5xl scroll-mt-20" aria-labelledby="projects-heading">
  <h2 id="projects-heading" class="max-lg:text-2xl text-3xl mb-3 w-fit mx-auto text-center font-bold text-secondary">Projects</h2>
  <p class="mx-auto mb-10 max-w-2xl text-center text-sm text-base-content/60">
    Selected work across product engineering, marketing sites, and independent web applications.
  </p>

  <div class="flex flex-col gap-3">
    {projects.map((project, i) => <ProjectCard {...project} index={i} />)}
  </div>
</section>
