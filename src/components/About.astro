---
// --- Enter Your Birth Date Below ---
const BIRTH_YEAR = 1997;
const BIRTH_MONTH_INDEX = 6; // IMPORTANT: Month is 0-indexed (0=Jan, 1=Feb, ..., 11=Dec)
const BIRTH_DAY = 4; // Day of the month (1-31)
// ---------------------------------
const today = new Date();
const birthDate = new Date(BIRTH_YEAR, BIRTH_MONTH_INDEX, BIRTH_DAY);

// Calculate the initial age difference in years
let age = today.getFullYear() - birthDate.getFullYear();

// Create a date object representing this year's birthday
const birthdayThisYear = new Date(today.getFullYear(), BIRTH_MONTH_INDEX, BIRTH_DAY);

// Check if the current date is *before* this year's birthday
// If it is, the person hasn't had their birthday yet this year, so subtract 1 from the age.
if (today < birthdayThisYear) {
  age--;
}
---

<section id="about" class="container scroll-mt-20 w-full max-w-screen-lg mx-auto" aria-labelledby="about-heading">
  <h2 id="about-heading" class="max-lg:text-2xl text-3xl mb-8 w-fit font-bold mx-auto text-secondary">About Me</h2>
