      <svg width="48" xmlns="http://www.w3.org/2000/svg" class="rounded-md inline" viewBox="0 0 37 28">
        <path fill="#c8102e" d="M0 0h37v28H0Z"></path><path stroke="#fff" stroke-width="4" d="M0 14h37M14 0v28"></path>
      </svg>
      <span class="font-semibold text-2xl text-center">Magnus Granno - {age}</span>
    </div>

    <div class="max-w-3xl space-y-4">
